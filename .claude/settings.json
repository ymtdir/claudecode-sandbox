{
  "permissions": {
    "allow": [
      // ファイル編集
      "Edit(*)",
      "Write(*)",

      // スキル
      "Skill(*)",

      // Git操作
      "Bash(git *)",
      "Bash(gh *)",

      // npm/node関連
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",

      // ファイル操作
      "Bash(ls*)",
      "Bash(tree*)",
      "Bash(pwd)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",

      // 開発ツール
      "Bash(which *)",
      "Bash(curl *)",

      // Web取得
      "WebFetch(*)",

      // MCP
      "mcp__github__*",
      "mcp__ide__*"
    ],
    "deny": [
      // システム破壊
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",

      // システムファイル編集
      "Edit(/etc/*)",
      "Write(/etc/*)",
      "Edit(/System/*)",
      "Write(/System/*)",
      "Edit(/usr/*)",
      "Write(/usr/*)",

      // 環境変数の危険な変更
      "Bash(export PATH=)",
      "Bash(unset PATH)",
      "Bash(export HOME=)",

      // ディスク操作
      "Bash(dd *)"
    ],
    "ask": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run format"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["github"]
}
